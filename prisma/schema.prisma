datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Picture {
  id         Int      @id @default(autoincrement())
  filetype   String
  bytes      Bytes
  date_taken DateTime

  train   Train  @relation(fields: [trainId], references: [id])
  trainId String

  service   Service @relation(fields: [serviceId], references: [id])
  serviceId String

  station   Station @relation(fields: [stationId], references: [name])
  stationId String
}

model Train {
  id       String    @id
  pictures Picture[]

  series   Series @relation(fields: [seriesId], references: [name])
  seriesId String
}

model Series {
  name   String  @id
  trains Train[]
}

model Service {
  id       String    @id
  pictures Picture[]

  origin   Station @relation("origin", fields: [originId], references: [name])
  originId String

  destination   Station @relation("destination", fields: [destinationId], references: [name])
  destinationId String
}

model Station {
  name                   String    @id
  country                String
  pictures               Picture[]
  services_starting_here Service[] @relation("origin")
  services_ending_here   Service[] @relation("destination")
}
